generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  FACILITY_ADMIN
  COORDINATION_MANAGER
  INVENTORY_MANAGER
}

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  LOCKED
  SUSPENDED
  DEACTIVATED
}

enum OnboardingRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ResourceType {
  BLOOD
  PPE
  MEDICATION
  MEDICAL_EQUIPMENT
}

enum InventoryUnit {
  UNITS
  TABLETS
  CAPSULES
  VIALS
  BOXES
  PACKS
  PIECES
  BOTTLES
}

enum FacilityType {
  HOSPITAL
  PHARMACY
  BLOOD_BANK
  PPE_SUPPLIER
}

enum FacilityStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InventoryStatus {
  AVAILABLE
  RESERVED
  UNAVAILABLE
  MAINTENANCE
  EXPIRED
  DEPLETED
}

enum StockMovementType {
  RESTOCK
  CONSUMPTION
  ADJUSTMENT
  EXPIRED_REMOVAL
  DAMAGE
  TRANSFER_OUT
  TRANSFER_IN
}

enum RequestStatus {
  PENDING
  ACCEPTED
  IN_TRANSIT
  COMPLETED
  CANCELLED
  REJECTED
  FAILED
  EXPIRED
}

enum RequestPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationType {
  REQUEST_CREATED
  REQUEST_ACKNOWLEDGED
  REQUEST_FULFILLED
  REQUEST_CANCELED
  REQUEST_EXPIRED
  BALANCE_LOW
  BALANCE_TOPUP
}

enum NotificationChannel {
  WEBSOCKET
  PUSH
  EMAIL
}


enum AuditAction {
  // Auth
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGED
  ACCOUNT_LOCKED

  // Onboarding
  ONBOARDING_REQUEST_SUBMITTED
  ONBOARDING_REQUEST_APPROVED
  ONBOARDING_REQUEST_REJECTED

  // Facility
  FACILITY_CREATED
  FACILITY_UPDATED
  FACILITY_SUSPENDED

  // User Management
  USER_CREATED
  USER_SUSPENDED
  USER_DEACTIVATED
  USER_ROLE_CHANGED

  // Inventory
  INVENTORY_CREATED
  INVENTORY_UPDATED
  INVENTORY_ADJUSTED
  INVENTORY_DELETED

  // Resource Requests
  REQUEST_CREATED
  REQUEST_ACCEPTED
  REQUEST_REJECTED
  REQUEST_COMPLETED
  REQUEST_CANCELLED
  REQUEST_DISPATCHED
  REQUEST_FAILED
}

model User {
  /// Primary Key
  id String @id @default(uuid())

  // ===========================================================================
  // Identity
  // ===========================================================================

  email        String @unique @db.VarChar(255)
  passwordHash String @db.VarChar(255)

  // ===========================================================================
  // Personal Information
  // ===========================================================================

  firstName String @db.VarChar(100)
  lastName  String @db.VarChar(100)
  phone     String? @db.VarChar(30)

  // ===========================================================================
  // Authorization
  // ===========================================================================

  role   UserRole
  status UserStatus @default(PENDING_APPROVAL)

  /// Nullable because SUPER_ADMIN does not belong to a facility.
  facilityId String?

  // ===========================================================================
  // Security
  // ===========================================================================

  emailVerified      Boolean   @default(false)
  emailVerifiedAt    DateTime?

  mustChangePassword Boolean @default(false)

  passwordChangedAt DateTime?

  failedLoginAttempts Int @default(0)

  lockedUntil DateTime?

  lastLoginAt DateTime?

  // ===========================================================================
  // Audit Metadata
  // ===========================================================================

  createdById String?

  registeredBySystem Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // ===========================================================================
  // Relationships
  // ===========================================================================

  facility Facility? @relation(fields: [facilityId], references: [id], onDelete: SetNull)

  createdBy User? @relation("UserCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdUsers User[] @relation("UserCreator")

  notifications               Notification[]
  notificationPreferences     UserNotificationPreference[]

  @@index([facilityId])
  @@index([role])
  @@index([status])
  @@index([createdById])
  @@index([email, status])
}

model Facility {
  id String @id @default(uuid())

  name String

  type FacilityType

  status FacilityStatus @default(ACTIVE)

  // ===========================================================================
  // Contact
  // ===========================================================================

  phone String @db.VarChar(30)

  email String @unique @db.VarChar(255)

  // ===========================================================================
  // Address
  // ===========================================================================

  region      String  @db.VarChar(100)
  district    String  @db.VarChar(100)
  addressLine String? @db.VarChar(255)

  // ===========================================================================
  // Geo Location
  // ===========================================================================

  latitude  Float
  longitude Float

  // ===========================================================================
  balance  Decimal @default(0.00) @db.Decimal(10, 2)

  // ===========================================================================
  // Relationships
  // ===========================================================================

  users       User[]
  inventories Inventory[]
  outgoingRequests ResourceRequest[] @relation("RequestingFacility")
  incomingRequests ResourceRequest[] @relation("SupplyingFacility")
  balanceTransactions BalanceTransaction[]
  notifications       Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([region, district])
}

model FacilityOnboardingRequest {
  id String @id @default(uuid())

  // ===========================================================================
  // Facility Information
  // ===========================================================================

  facilityName String
  facilityType FacilityType

  // ===========================================================================
  // Facility Contact
  // ===========================================================================

  facilityPhone String  @db.VarChar(30)
  facilityEmail String  @db.VarChar(255)

  // ===========================================================================
  // Facility Address
  // ===========================================================================

  region      String  @db.VarChar(100)
  district    String  @db.VarChar(100)
  addressLine String? @db.VarChar(255)

  // ===========================================================================
  // Facility Geo Location
  // ===========================================================================

  latitude  Float
  longitude Float

  // ===========================================================================
  // Initial Facility Administrator
  // ===========================================================================

  adminFirstName String
  adminLastName  String
  adminEmail     String  @unique
  adminPhone     String?

  // ===========================================================================
  // Review Status
  // ===========================================================================

  status OnboardingRequestStatus @default(PENDING)

  rejectionReason String?

  // ===========================================================================
  // Metadata
  // ===========================================================================

  submittedAt DateTime @default(now())
  reviewedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([facilityType])
}

model AuditLog {
  id String @id @default(uuid())

  // ===========================================================================
  // Actor
  // ===========================================================================

  /// Stored as plain string — no FK so logs survive user deletion
  actorId   String?

  /// Snapshot of the actor's role at the time of the action
  actorRole String?

  // ===========================================================================
  // Action
  // ===========================================================================

  action AuditAction

  // ===========================================================================
  // Target Entity
  // ===========================================================================

  entityType String
  entityId   String

  // ===========================================================================
  // Context
  // ===========================================================================

  /// Null for SUPER_ADMIN and system-level actions
  facilityId String?

  // ===========================================================================
  // Change Snapshot (minimal — only populated where meaningful)
  // ===========================================================================

  previousValue Json?
  newValue      Json?

  // ===========================================================================
  // Request Metadata
  // ===========================================================================

  ipAddress String?
  userAgent String?

  // ===========================================================================
  // Timestamp
  // ===========================================================================

  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([facilityId])
  @@index([action])
  @@index([createdAt])
}

model Inventory {
  id String @id @default(uuid())

  // ===========================================================================
  // Ownership
  // ===========================================================================

  facilityId String

  // ===========================================================================
  // Resource
  // ===========================================================================

  resourceType ResourceType

  itemName String @db.VarChar(255)

  unit InventoryUnit

  status InventoryStatus @default(AVAILABLE)

  /// Optional — when set, a LowStockAlert fires when derived quantity falls below this
  lowStockThreshold Int?

  /// Optional — when set, a warning fires if a request would bring stock below this level
  reservedThreshold Int?

  price             Decimal?        @db.Decimal(10, 2)
  isMovable         Boolean         @default(true)


  // ===========================================================================
  // Type-specific Metadata (discriminated by resourceType)
  // ===========================================================================

  metadata Json

  // ===========================================================================
  // Audit Metadata
  // ===========================================================================

  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // ===========================================================================
  // Relationships
  // ===========================================================================

  facility       Facility        @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]
  lowStockAlerts LowStockAlert[]

  @@index([facilityId])
  @@index([resourceType])
  @@index([status])
  @@index([facilityId, resourceType])
  @@index([facilityId, status])
}

model StockMovement {
  id String @id @default(uuid())

  // ===========================================================================
  // Target
  // ===========================================================================

  inventoryId String

  /// Denormalized for efficient facility-scoped queries
  facilityId String

  // ===========================================================================
  // Movement
  // ===========================================================================

  /// Signed integer — positive = stock in, negative = stock out
  quantity Int

  movementType StockMovementType

  reason String? @db.VarChar(500)

  // ===========================================================================
  // Actor
  // ===========================================================================

  performedById String

  /// Optional — links to a resource request when movement is a transfer
  referenceId String?

  // ===========================================================================
  // Timestamp (immutable — no updatedAt)
  // ===========================================================================

  createdAt DateTime @default(now())

  // ===========================================================================
  // Relationships
  // ===========================================================================

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([facilityId])
  @@index([movementType])
  @@index([performedById])
  @@index([inventoryId, createdAt])
}

model LowStockAlert {
  id String @id @default(uuid())

  // ===========================================================================
  // Target
  // ===========================================================================

  inventoryId String

  /// Denormalized for efficient facility-scoped queries
  facilityId String

  // ===========================================================================
  // Alert Snapshot
  // ===========================================================================

  /// Threshold value at the time the alert was triggered
  thresholdAtTime Int

  /// Quantity that triggered the alert
  quantityAtTime Int

  // ===========================================================================
  // Resolution
  // ===========================================================================

  /// Null = active alert, set = resolved
  resolvedAt DateTime?

  // ===========================================================================
  // Timestamps (immutable — no updatedAt)
  // ===========================================================================

  createdAt DateTime @default(now())

  // ===========================================================================
  // Relationships
  // ===========================================================================

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([facilityId])
  @@index([facilityId, resolvedAt])
  @@index([inventoryId, resolvedAt])
}

model ResourceRequest {
  id String @id @default(uuid())

  // ===========================================================================
  // Parties
  // ===========================================================================

  requestingFacilityId String

  /// Set when a supplier accepts the request
  supplyingFacilityId String?

  /// COORDINATION_MANAGER who created the request
  requestedById String

  /// User who accepted / rejected the request
  handledById String?

  // ===========================================================================
  // Resource
  // ===========================================================================

  resourceType ResourceType

  itemName String @db.VarChar(255)

  quantity Int

  unit InventoryUnit

  // ===========================================================================
  // Request Details
  // ===========================================================================

  priority RequestPriority

  status RequestStatus @default(PENDING)

  description String @db.VarChar(1000)

  isEmergency Boolean @default(false)
  isBroadcast Boolean @default(false)
  maxRadiusKm Int?    @default(50)
  declinedBy  String[]

  pricePerUnit   Decimal?        @db.Decimal(10, 2)
  totalAmount    Decimal?        @db.Decimal(10, 2)
  paymentStatus  String          @default("paid")
  transactionId  String?

  /// Optional patient context (stored as JSON snapshot)
  patient Json?

  // ===========================================================================
  // Resolution
  // ===========================================================================

  rejectionReason   String? @db.VarChar(500)

  cancellationReason String? @db.VarChar(500)

  // ===========================================================================
  // Timeline
  // ===========================================================================

  requestedAt  DateTime  @default(now())
  acceptedAt   DateTime?
  dispatchedAt DateTime?
  completedAt  DateTime?
  expiresAt    DateTime?

  // ===========================================================================
  // Audit Metadata
  // ===========================================================================

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ===========================================================================
  // Relationships
  // ===========================================================================

  requestingFacility Facility  @relation("RequestingFacility", fields: [requestingFacilityId], references: [id])
  supplyingFacility  Facility? @relation("SupplyingFacility",  fields: [supplyingFacilityId],  references: [id])

  @@index([requestingFacilityId])
  @@index([supplyingFacilityId])
  @@index([status])
  @@index([priority])
  @@index([resourceType])
  @@index([requestedById])
  @@index([requestingFacilityId, status])
  @@index([supplyingFacilityId, status])
}

model UserInvitation {
  id String @id @default(uuid())

  // ===========================================================================
  // Target
  // ===========================================================================

  /// The pending user this invitation is for
  userId String @unique

  facilityId String?

  // ===========================================================================
  // Token
  // ===========================================================================

  /// bcrypt hash of the raw invitation token — never store raw
  tokenHash String

  expiresAt DateTime

  /// Set when the invitation is accepted
  usedAt DateTime?

  // ===========================================================================
  // Audit
  // ===========================================================================

  createdById String

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([facilityId])
}

model BalanceTransaction {
  id            String   @id @default(uuid())
  facilityId    String
  amount        Decimal  @db.Decimal(10, 2)
  type          String
  reference     String?
  paymentMethod String
  status        String
  description   String?
  createdAt     DateTime @default(now())

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([facilityId])
  @@index([type])
  @@index([status])
}

model Notification {
  id         String              @id @default(uuid())
  userId     String
  facilityId String
  type       NotificationType
  channel    NotificationChannel
  title      String
  body       String
  data       Json?

  readAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([facilityId])
  @@index([type])
  @@index([readAt])
}

model UserNotificationPreference {
  id            String              @id @default(uuid())
  userId        String
  channel       NotificationChannel
  enabled       Boolean             @default(true)
  emergencyOnly Boolean             @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, channel])
  @@index([userId])
}
