generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  FACILITY_ADMIN
  COORDINATION_MANAGER
  INVENTORY_MANAGER
}

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  LOCKED
  SUSPENDED
  DEACTIVATED
}

enum OnboardingRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FacilityType {
  HOSPITAL
  PHARMACY
  BLOOD_BANK
  PPE_SUPPLIER
}

enum FacilityStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  /// Primary Key
  id String @id @default(uuid())

  // ===========================================================================
  // Identity
  // ===========================================================================

  email        String @unique @db.VarChar(255)
  passwordHash String @db.VarChar(255)

  // ===========================================================================
  // Personal Information
  // ===========================================================================

  firstName String @db.VarChar(100)
  lastName  String @db.VarChar(100)
  phone     String? @db.VarChar(30)

  // ===========================================================================
  // Authorization
  // ===========================================================================

  role   UserRole
  status UserStatus @default(PENDING_APPROVAL)

  /// Nullable because SUPER_ADMIN does not belong to a facility.
  facilityId String?

  // ===========================================================================
  // Security
  // ===========================================================================

  emailVerified      Boolean   @default(false)
  emailVerifiedAt    DateTime?

  mustChangePassword Boolean @default(false)

  passwordChangedAt DateTime?

  failedLoginAttempts Int @default(0)

  lockedUntil DateTime?

  lastLoginAt DateTime?

  // ===========================================================================
  // Audit Metadata
  // ===========================================================================

  createdById String?

  registeredBySystem Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // ===========================================================================
  // Relationships
  // ===========================================================================

  facility Facility? @relation(fields: [facilityId], references: [id], onDelete: SetNull)

  createdBy User? @relation("UserCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdUsers User[] @relation("UserCreator")

  @@index([facilityId])
  @@index([role])
  @@index([status])
  @@index([createdById])
  @@index([email, status])
}

model Facility {
  id String @id @default(uuid())

  name String

  type FacilityType

  status FacilityStatus @default(ACTIVE)

  // ===========================================================================
  // Contact
  // ===========================================================================

  phone String @db.VarChar(30)

  email String @unique @db.VarChar(255)

  // ===========================================================================
  // Address
  // ===========================================================================

  region      String  @db.VarChar(100)
  district    String  @db.VarChar(100)
  addressLine String? @db.VarChar(255)

  // ===========================================================================
  // Geo Location
  // ===========================================================================

  latitude  Float
  longitude Float

  // ===========================================================================
  // Relationships
  // ===========================================================================

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([region, district])
}

model FacilityOnboardingRequest {
  id String @id @default(uuid())

  // ===========================================================================
  // Facility Information
  // ===========================================================================

  facilityName String
  facilityType FacilityType

  // ===========================================================================
  // Facility Contact
  // ===========================================================================

  facilityPhone String  @db.VarChar(30)
  facilityEmail String  @db.VarChar(255)

  // ===========================================================================
  // Facility Address
  // ===========================================================================

  region      String  @db.VarChar(100)
  district    String  @db.VarChar(100)
  addressLine String? @db.VarChar(255)

  // ===========================================================================
  // Facility Geo Location
  // ===========================================================================

  latitude  Float
  longitude Float

  // ===========================================================================
  // Initial Facility Administrator
  // ===========================================================================

  adminFirstName String
  adminLastName  String
  adminEmail     String  @unique
  adminPhone     String?

  // ===========================================================================
  // Review Status
  // ===========================================================================

  status OnboardingRequestStatus @default(PENDING)

  rejectionReason String?

  // ===========================================================================
  // Metadata
  // ===========================================================================

  submittedAt DateTime @default(now())
  reviewedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([facilityType])
}